# --- Public site / Next.js ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Clerk authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin/dashboard

# Comma-separated allowlist of emails permitted to access /admin
ADMIN_ALLOWED_EMAILS=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- hCaptcha (spam protection) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# --- Optional rate limit (Upstash); if unset, falls back to in-memory ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Privacy: when 'true', subscriber/inquiry IPs are not stored
DO_NOT_TRACK=false
